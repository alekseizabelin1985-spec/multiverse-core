{
  "mcpServers": {
    "memory-new": {
      "type": "http",
      "url": "http://localhost:3001/mcp"
    },
    "context7": {
      "type": "http",
      "url": "http://localhost:3002/mcp"
    },1
    "qdrant": {
      "type": "http",
      "url": "http://localhost:6333"
    },
    "kafka": {
      "command": "mcp-kafka",
      "env": {
        "KAFKA_BOOTSTRAP_SERVERS": "localhost:9092",
        "KAFKA_CLIENT_ID": "multiverse-mcp",
